# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/Build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local dev config
AGENTS.md
CLAUDE.md
PRE_PRODUCTION.md
REPARACIONES-*.md
REPORTE-*.md

# opencode
.opencode/

# supabase migrations (se ejecutan manualmente en Dashboard)
supabase/

